# Environment Configuration for Service Principal Authentication

# Copy this to your .env file and fill in your actual values

# Databricks workspace URL (without trailing slash)
#DATABRICKS_HOST=https://your-workspace.cloud.databricks.com

# Service Principal credentials
# Get these from your Databricks workspace under "App registrations" or "Service principals"
#DATABRICKS_CLIENT_ID=your-service-principal-client-id
#DATABRICKS_CLIENT_SECRET=your-service-principal-client-secret

# Optional: Additional configuration
# DATABRICKS_SCOPE=all-apis
