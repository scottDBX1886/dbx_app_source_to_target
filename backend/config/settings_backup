"""
Application settings using Pydantic BaseSettings.

This module defines the application settings that can be set
via environment variables.
"""

"""
Application settings using environment variables.
"""
import os
from typing import Optional

class Settings:
    """Application settings."""
    
    def __init__(self):
        # Databricks SQL warehouse ID
        self.databricks_warehouse_id: Optional[str] = os.getenv("DATABRICKS_WAREHOUSE_ID")
        
        # Default values for pagination
        self.default_limit: int = int(os.getenv("DEFAULT_LIMIT", "100"))
        self.max_limit: int = int(os.getenv("MAX_LIMIT", "1000"))

# Create a singleton instance of the settings
settings = Settings()

def get_settings() -> Settings:
    """Get the application settings."""
    return settings
